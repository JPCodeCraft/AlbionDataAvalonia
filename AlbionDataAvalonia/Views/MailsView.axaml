<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:vm="clr-namespace:AlbionDataAvalonia.ViewModels"
             x:Class="AlbionDataAvalonia.Views.MailsView"
			 x:DataType="vm:MailsViewModel"
             xmlns:items="clr-namespace:AlbionDataAvalonia.Items"
			 xmlns:model="using:AlbionDataAvalonia.Network.Models">

	<UserControl.Styles>
		<Style Selector="Button.Filter">
			<Setter Property="Padding" Value="10" />
			<Setter Property="Margin" Value="10" />
		</Style>
		<Style Selector="Button.ActionButton">
			<Setter Property="Padding" Value="6,4" />
			<Setter Property="Margin" Value="0,0,10,6" />
			<Setter Property="HorizontalContentAlignment" Value="Center" />
			<Setter Property="VerticalContentAlignment" Value="Center" />
		</Style>
		<Style Selector="TextBox.Filter">
			<Setter Property="Padding" Value="10" />
			<Setter Property="Margin" Value="0,0,10,6" />
		</Style>
		<Style Selector="ComboBox.Filter">
			<Setter Property="Padding" Value="10" />
			<Setter Property="Margin" Value="0,0,10,6" />
		</Style>
        <Style Selector="TextBlock.FilterLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="Margin" Value="0,0,0,1"/>
        </Style>
        <Style Selector="TextBlock.SelectedSummaryLabel">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#888"/>
        </Style>
        <Style Selector="TextBlock.SelectedSummaryValue">
            <Setter Property="FontSize" Value="11"/>
        </Style>
	</UserControl.Styles>

	<Grid ColumnDefinitions="*" RowDefinitions="Auto, Auto, *">

		<WrapPanel VerticalAlignment="Top" Margin="0,8,0,8">

            <StackPanel Orientation="Vertical" Spacing="0" Margin="0,0,10,0" HorizontalAlignment="Left" VerticalAlignment="Top">
                <TextBlock Classes="FilterLabel" Text="Data"/>
                <Button Classes="Filter ActionButton" Width="100" Content="Load" Command="{Binding LoadMailsCommand}" />
                <Button Classes="Filter ActionButton" Width="100" Content="Export CSV" Name="ExportCsvButton" Click="ExportCsvButton_Click" IsEnabled="{Binding !IsExporting}" />
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="0,0,10,0" HorizontalAlignment="Left" VerticalAlignment="Top" IsVisible="{Binding IsExporting}">
                <ProgressBar Minimum="0" Maximum="100" Value="{Binding ExportProgress}" Width="150" Height="20" />
            </StackPanel>

	            <StackPanel Orientation="Vertical" Margin="0,0,10,0" HorizontalAlignment="Left" VerticalAlignment="Top">
	                <TextBlock Classes="FilterLabel" Text="Search an Item..."/>
	                <TextBox Classes="Filter" Text="{Binding FilterText}" Name="FilterBox" Width="250"/>
	            </StackPanel>

	            <StackPanel Orientation="Vertical" Margin="0,0,10,0" HorizontalAlignment="Left" VerticalAlignment="Top">
	                <TextBlock Classes="FilterLabel" Text="Mails to load"/>
	                <ComboBox Classes="Filter" ItemsSource="{Binding MailsToLoadOptions}" SelectedItem="{Binding SelectedMailsToLoad}" Width="120"/>
	            </StackPanel>

	            <StackPanel Orientation="Vertical" Margin="0,0,10,0" HorizontalAlignment="Left" VerticalAlignment="Top">
	                <TextBlock Classes="FilterLabel" Text="Server"/>
	                <ComboBox Classes="Filter" ItemsSource="{Binding Servers}" SelectedItem="{Binding SelectedServer}" Width="150">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="0,0,10,0" HorizontalAlignment="Left" VerticalAlignment="Top">
                <TextBlock Classes="FilterLabel" Text="Operation"/>
                <ComboBox Classes="Filter" ItemsSource="{Binding AuctionTypes}" SelectedItem="{Binding SelectedType}" Width="100">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="0,0,10,0" HorizontalAlignment="Left" VerticalAlignment="Top">
                <TextBlock Classes="FilterLabel" Text="Location"/>
                <ComboBox Classes="Filter" ItemsSource="{Binding Locations}" SelectedItem="{Binding SelectedLocation}" Width="150">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <StackPanel Orientation="Vertical" Spacing="0" Margin="0,0,10,0" HorizontalAlignment="Left" VerticalAlignment="Top">
                <TextBlock Classes="FilterLabel" Text="Cleanup"/>
                <Button Classes="Filter ActionButton" Width="100" Content="Cleanup" Name="CleanupButton" Click="CleanupButton_Click" />
                <Button Classes="Filter ActionButton" Width="100" Content="Delete" Name="DeleteButton" Click="DeleteButton_Click" IsEnabled="{Binding HasSelectedRows}" />
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="0,0,10,0" HorizontalAlignment="Left" VerticalAlignment="Top" IsVisible="{Binding HasSelectedRows}">
                <TextBlock Classes="FilterLabel" Text="Selected Totals"/>
                <StackPanel Orientation="Vertical" Spacing="2" VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Classes="SelectedSummaryLabel" Text="Amount:" VerticalAlignment="Center" />
                        <TextBlock Classes="SelectedSummaryValue" Text="{Binding SelectedAmountTotal, StringFormat='{}{0:N0}'}" Tag="{Binding SelectedAmountTotal}" VerticalAlignment="Center" Cursor="Hand" PointerPressed="CopyValuePointerPressed" ToolTip.Tip="Click to copy" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Classes="SelectedSummaryLabel" Text="Total Silver:" VerticalAlignment="Center" />
                        <TextBlock Classes="SelectedSummaryValue" Text="{Binding SelectedTotalSilver, StringFormat='{}{0:N0}'}" Tag="{Binding SelectedTotalSilver}" VerticalAlignment="Center" Cursor="Hand" PointerPressed="CopyValuePointerPressed" ToolTip.Tip="Click to copy" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Classes="SelectedSummaryLabel" Text="Avg Silver:" VerticalAlignment="Center" />
                        <TextBlock Classes="SelectedSummaryValue" Text="{Binding SelectedAverageSilver, StringFormat='{}{0:N2}'}" Tag="{Binding SelectedAverageSilver}" VerticalAlignment="Center" Cursor="Hand" PointerPressed="CopyValuePointerPressed" ToolTip.Tip="Click to copy" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>

        </WrapPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="4,0,0,8"
                    IsVisible="{Binding HasCleanupStatus}">
            <TextBlock Text="{Binding CleanupStatus}" TextWrapping="Wrap" FontSize="12" />
        </StackPanel>

		<DataGrid Grid.Row="2" Margin="0" ItemsSource="{Binding Mails}"
                  Name="MailsGrid"
				  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Extended"
                  SelectionChanged="MailsGrid_SelectionChanged"
				  GridLinesVisibility="None"
				  BorderThickness="0" BorderBrush="Gray">

			<DataGrid.Styles>
				<Style Selector="DataGridColumnHeader /template/ Grid#PART_ColumnHeaderRoot">
					<Setter Property="Background" Value="rgba(255, 255, 255, 0.2)" />
				</Style>
				<Style Selector="DataGridColumnHeader:pointerover /template/ Grid#PART_ColumnHeaderRoot">
					<Setter Property="Background" Value="rgba(255, 255, 255, 0.4)" />
				</Style>
			</DataGrid.Styles>

			<DataGrid.Columns>
				<DataGridTextColumn Header="Server" Binding="{Binding Server.Name}" />
				<DataGridTextColumn Header="Player" Binding="{Binding PlayerName}" />
				<DataGridTextColumn Header="Received" Binding="{Binding Received}" />
				<DataGridTextColumn Header="Type" Binding="{Binding AuctionTypeFormatted}" />
				<DataGridTemplateColumn Header="Item" SortMemberPath="ItemName" CanUserSort="True">
					<DataGridTemplateColumn.CellTemplate>
						<DataTemplate>
							<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
								<Image Width="30" Height="30" Stretch="Uniform"
                                       items:LazyItemImage.ItemUniqueName="{Binding ItemId}"
                                       items:LazyItemImage.Quality="{Binding ImageQuality}" />
								<TextBlock Text="{Binding ItemName}" VerticalAlignment="Center" />
							</StackPanel>
						</DataTemplate>
					</DataGridTemplateColumn.CellTemplate>
				</DataGridTemplateColumn>
				<DataGridTextColumn Header="Location" Binding="{Binding Location.FriendlyName}" />

				<DataGridTemplateColumn Header="Amount" CanUserSort="True" SortMemberPath="PartialAmount">
					<DataGridTemplateColumn.CellTemplate>
						<DataTemplate>
							<TextBlock Text="{Binding PartialAmount, StringFormat='{}{0:N0}'}" VerticalAlignment="Center" HorizontalAlignment="Center" />
						</DataTemplate>
					</DataGridTemplateColumn.CellTemplate>
				</DataGridTemplateColumn>

				<DataGridTemplateColumn Header="Order Amount" CanUserSort="True" SortMemberPath="PartialAmount">
					<DataGridTemplateColumn.CellTemplate>
						<DataTemplate>
							<TextBlock Text="{Binding TotalAmount, StringFormat='{}{0:N0}'}" VerticalAlignment="Center" HorizontalAlignment="Center" />
						</DataTemplate>
					</DataGridTemplateColumn.CellTemplate>
				</DataGridTemplateColumn>

				<DataGridTemplateColumn Header="Unit Silver" CanUserSort="True"  SortMemberPath="UnitSilver">
					<DataGridTemplateColumn.CellTemplate>
						<DataTemplate>
							<TextBlock Text="{Binding UnitSilver, StringFormat='{}{0:N2}'}" VerticalAlignment="Center" HorizontalAlignment="Center" />
						</DataTemplate>
					</DataGridTemplateColumn.CellTemplate>
				</DataGridTemplateColumn>

				<DataGridTemplateColumn Header="Total Silver" CanUserSort="True"  SortMemberPath="TotalSilver">
					<DataGridTemplateColumn.CellTemplate>
						<DataTemplate>
							<TextBlock Text="{Binding TotalSilver, StringFormat='{}{0:N0}'}" VerticalAlignment="Center" HorizontalAlignment="Center" />
						</DataTemplate>
					</DataGridTemplateColumn.CellTemplate>
				</DataGridTemplateColumn>

			</DataGrid.Columns>
		</DataGrid>
	</Grid>



</UserControl>
