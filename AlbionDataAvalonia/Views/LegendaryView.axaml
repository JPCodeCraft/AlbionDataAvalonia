<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AlbionDataAvalonia.ViewModels"
             xmlns:items="clr-namespace:AlbionDataAvalonia.Items"
             mc:Ignorable="d"
             d:DesignWidth="1100" d:DesignHeight="650"
             x:Class="AlbionDataAvalonia.Views.LegendaryView"
             x:DataType="vm:LegendaryViewModel">
    <UserControl.Styles>
        <Style Selector="Border.DetailSection">
            <Setter Property="Background" Value="rgba(255,255,255,0.045)" />
            <Setter Property="BorderBrush" Value="rgba(255,255,255,0.11)" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
        </Style>
        <Style Selector="Border.OrderCard">
            <Setter Property="Background" Value="#252525" />
            <Setter Property="BorderBrush" Value="#4A4A4A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style Selector="TextBlock.SectionTitle">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="DemiBold" />
        </Style>
        <Style Selector="TextBlock.DetailLabel">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Opacity" Value="0.65" />
        </Style>
        <Style Selector="Button.NeutralAction">
            <Setter Property="Background" Value="#3A3A3A" />
            <Setter Property="BorderBrush" Value="#505050" />
        </Style>
        <Style Selector="Button.NeutralAction:pointerover">
            <Setter Property="Background" Value="#484848" />
        </Style>
    </UserControl.Styles>
    <Grid RowDefinitions="Auto,Auto,*" ColumnDefinitions="*">
        <WrapPanel Margin="0,8,0,8"
                   VerticalAlignment="Top"
                   IsVisible="{Binding !IsAwakeningItemsTrackerDisabled}">
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Search" FontSize="12" Foreground="#888" />
                <TextBox Text="{Binding FilterText}" Width="260" Padding="8" />
            </StackPanel>
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Server" FontSize="12" Foreground="#888" />
                <ComboBox ItemsSource="{Binding Servers}" SelectedItem="{Binding SelectedServer}" Width="140" Padding="8" />
            </StackPanel>
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Filters" FontSize="12" Foreground="#888" />
                <CheckBox Content="Only Attuned to Me"
                          IsChecked="{Binding OnlyAttunedToMe}"
                          IsEnabled="{Binding CanFilterAttunedToMe}"
                          Padding="0,4" />
            </StackPanel>
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Sale status" FontSize="12" Foreground="#888" />
                <ComboBox ItemsSource="{Binding SaleStatuses}"
                          SelectedItem="{Binding SelectedSaleStatus}"
                          Width="140"
                          Padding="8" />
            </StackPanel>
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Data" FontSize="12" Foreground="#888" />
                <Button Content="Refresh" Command="{Binding RefreshCommand}" Padding="12,8" />
            </StackPanel>
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Entries" FontSize="12" Foreground="#888" />
                <Button Content="Delete selected"
                        Click="DeleteSelectedButton_Click"
                        Padding="12,8" />
            </StackPanel>
        </WrapPanel>

        <TextBlock Grid.Row="1"
                   Margin="2,0,2,8"
                   Text="{Binding SaleStatus}"
                   FontSize="11"
                   IsVisible="{Binding !IsAwakeningItemsTrackerDisabled}"
                   TextWrapping="Wrap" />

        <Grid Grid.Row="2"
              ColumnSpacing="12"
              IsVisible="{Binding !IsAwakeningItemsTrackerDisabled}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="13*" />
                <ColumnDefinition Width="7*" MinWidth="340" MaxWidth="430" />
            </Grid.ColumnDefinitions>
            <DataGrid Name="LegendaryItemsGrid"
                      Grid.Column="0"
                      ItemsSource="{Binding Items}"
                      SelectedItem="{Binding SelectedItem}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Extended"
                      GridLinesVisibility="None"
                      BorderThickness="0"
                      FontSize="11">
                <DataGrid.Styles>
                    <Style Selector="DataGridColumnHeader">
                        <Setter Property="FontSize" Value="11" />
                    </Style>
                    <Style Selector="DataGridColumnHeader /template/ Grid#PART_ColumnHeaderRoot">
                        <Setter Property="Background" Value="rgba(255,255,255,0.2)" />
                    </Style>
                    <Style Selector="DataGridColumnHeader:pointerover /template/ Grid#PART_ColumnHeaderRoot">
                        <Setter Property="Background" Value="rgba(255,255,255,0.4)" />
                    </Style>
                </DataGrid.Styles>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Server" Binding="{Binding ServerName}" />
                    <DataGridTemplateColumn Header="Item" SortMemberPath="ItemName" CanUserSort="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="vm:LegendaryItemRowViewModel">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Image Width="28" Height="28" Stretch="Uniform"
                                           items:LazyItemImage.ItemUniqueName="{Binding ItemUniqueName}"
                                           items:LazyItemImage.Quality="{Binding ImageQuality}" />
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ItemName}" FontSize="11" />
                                        <TextBlock Text="{Binding Quality}"
                                                   FontSize="10"
                                                   Opacity="0.65" />
                                        <TextBlock Text="{Binding SoulName}"
                                                   IsVisible="{Binding HasSoulName}"
                                                   FontSize="10"
                                                   Opacity="0.65" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Attuned to" Binding="{Binding AttunedTo}" SortMemberPath="Source.AttunedToPlayerName" />
                    <DataGridTextColumn Header="Rating" Binding="{Binding LegendaryRating}" SortMemberPath="LegendaryRatingValue" />
                    <DataGridTextColumn Header="Strain" Binding="{Binding Strain}" SortMemberPath="Source.Strain" />
                    <DataGridTextColumn Header="PvP fame" Binding="{Binding PvPFameGained}" SortMemberPath="Source.PvPFameGained" />
                    <DataGridTextColumn Header="Attunement spent" Binding="{Binding AttunementSpent}" SortMemberPath="Source.AttunementSpent" />
                    <DataGridTextColumn Header="Last seen" Binding="{Binding LastSeen}" SortMemberPath="Source.LastSeenAtUtc" />
                    <DataGridTextColumn Header="Sale status" Binding="{Binding SaleState}" SortMemberPath="SaleState" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="1"
                    MinWidth="340"
                    MaxWidth="430"
                    Background="rgba(255,255,255,0.025)"
                    CornerRadius="8"
                    Padding="10">
                <Grid>
                    <TextBlock Text="Select an item to view its details."
                               IsVisible="{Binding !HasSelectedItem}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               Opacity="0.7" />
                    <ScrollViewer IsVisible="{Binding HasSelectedItem}">
                        <StackPanel Spacing="10" Margin="0,0,10,0">
                            <Border Classes="DetailSection">
                                <StackPanel Spacing="10">
                                    <Grid ColumnDefinitions="72,*,Auto" ColumnSpacing="10">
                                        <Image Width="68"
                                               Height="68"
                                               Stretch="Uniform"
                                               items:LazyItemImage.ItemUniqueName="{Binding SelectedItem.ItemUniqueName}"
                                               items:LazyItemImage.Quality="{Binding SelectedItem.ImageQuality}" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="{Binding SelectedItem.ItemName}"
                                                       FontSize="17"
                                                       FontWeight="DemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding SelectedItem.SoulName}"
                                                       IsVisible="{Binding SelectedItem.HasSoulName}"
                                                       FontStyle="Italic"
                                                       Opacity="0.7"
                                                       TextWrapping="Wrap" />
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding SelectedItem.ServerName}" FontSize="11" Opacity="0.7" />
                                                <TextBlock Text="{Binding SelectedItem.Quality}" FontSize="11" Foreground="#F0B94A" />
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="Rating" FontSize="10" Opacity="0.6" HorizontalAlignment="Right" />
                                            <TextBlock Text="{Binding SelectedItem.LegendaryRating}"
                                                       FontSize="20"
                                                       FontWeight="DemiBold"
                                                       Foreground="#F0A21B"
                                                       HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Grid>
                                    <WrapPanel>
                                        <Button Content="View in calculator"
                                                Classes="NeutralAction"
                                                Tag="{Binding SelectedItem.CalculatorUrl}"
                                                IsEnabled="{Binding SelectedItem.CanViewInCalculator}"
                                                Click="OpenCalculatorButton_Click"
                                                Margin="0,0,8,0"
                                                Padding="10,6" />
                                        <Button Name="ListForSaleButton"
                                                Classes="NeutralAction"
                                                Content="{Binding SelectedItem.SaleActionText, TargetNullValue='List for sale'}"
                                                IsEnabled="{Binding CanListSelectedItem}"
                                                Click="ListForSaleButton_Click"
                                                Padding="10,6" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                                  RowSpacing="10"
                                  DataContext="{Binding SelectedItem}">
                                <Border Grid.Row="2" Classes="DetailSection">
                                    <StackPanel Spacing="10">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <TextBlock Classes="SectionTitle" Text="Sale listing" VerticalAlignment="Center" />
                                            <Border Grid.Column="1" Background="#4B4B4B" CornerRadius="10" Padding="9,3" IsVisible="{Binding !HasListing}">
                                                <TextBlock Text="Not listed" FontSize="11" FontWeight="DemiBold" />
                                            </Border>
                                            <Border Grid.Column="1" Background="#356B3D" CornerRadius="10" Padding="9,3" IsVisible="{Binding IsActiveListing}">
                                                <TextBlock Text="Active" FontSize="11" FontWeight="DemiBold" />
                                            </Border>
                                            <Border Grid.Column="1" Background="#7A6230" CornerRadius="10" Padding="9,3" IsVisible="{Binding IsSold}">
                                                <TextBlock Text="Sold" FontSize="11" FontWeight="DemiBold" />
                                            </Border>
                                            <Border Grid.Column="1" Background="#70413D" CornerRadius="10" Padding="9,3" IsVisible="{Binding IsCanceled}">
                                                <TextBlock Text="Canceled" FontSize="11" FontWeight="DemiBold" />
                                            </Border>
                                        </Grid>

                                        <TextBlock Text="{Binding SaleStatusSummary}"
                                                   TextWrapping="Wrap"
                                                   Opacity="0.8" />

                                        <Grid IsVisible="{Binding HasListing}"
                                              ColumnDefinitions="*,*"
                                              ColumnSpacing="16">
                                            <StackPanel>
                                                <TextBlock Classes="DetailLabel" Text="Current price" />
                                                <TextBlock Text="{Binding LatestPrice}"
                                                           FontSize="17"
                                                           FontWeight="DemiBold" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Classes="DetailLabel" Text="Last listed" />
                                                <TextBlock Text="{Binding LastListed}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>

                                        <WrapPanel IsVisible="{Binding HasListing}">
                                            <CheckBox Name="SoldCheckBox"
                                                      Content="Mark as sold"
                                                      IsVisible="{Binding !IsCanceled}"
                                                      IsChecked="{Binding IsSold, Mode=OneWay}"
                                                      IsEnabled="{Binding CanChangeSold}"
                                                      Click="SoldCheckBox_Click"
                                                      Margin="0,0,12,0" />
                                            <Button Content="Cancel listing"
                                                    Classes="NeutralAction"
                                                    IsVisible="{Binding IsActiveListing}"
                                                    Click="CancelListingButton_Click"
                                                    Padding="8,4" />
                                        </WrapPanel>

                                        <Expander Header="{Binding SellOrdersHeading}"
                                                  IsVisible="{Binding HasListing}"
                                                  IsExpanded="False"
                                                  Background="#202020"
                                                  BorderBrush="#4A4A4A"
                                                  BorderThickness="1"
                                                  CornerRadius="6">
                                            <Expander.Resources>
                                                <SolidColorBrush x:Key="ExpanderHeaderBackground" Color="#303030" />
                                                <SolidColorBrush x:Key="ExpanderHeaderBackgroundPointerOver" Color="#383838" />
                                                <SolidColorBrush x:Key="ExpanderHeaderBackgroundPressed" Color="#404040" />
                                            </Expander.Resources>
                                            <StackPanel Margin="0,8,0,0">
                                                <TextBlock Text="No sale orders have been recorded."
                                                           IsVisible="{Binding !HasSellOrders}"
                                                           Opacity="0.65"
                                                           TextWrapping="Wrap" />
                                                <ItemsControl ItemsSource="{Binding SellOrders}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:LegendarySellOrderRowViewModel">
                                                            <Border Classes="OrderCard">
                                                                <StackPanel Spacing="7">
                                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding Price}"
                                                                                       FontSize="16"
                                                                                       FontWeight="DemiBold" />
                                                                            <TextBlock Text="{Binding ListedAt}"
                                                                                       FontSize="11"
                                                                                       Opacity="0.65" />
                                                                        </StackPanel>
                                                                        <Border Grid.Column="1"
                                                                                Background="#303030"
                                                                                CornerRadius="8"
                                                                                Padding="7,2"
                                                                                VerticalAlignment="Top">
                                                                            <TextBlock Text="{Binding OrderLabel}"
                                                                                       FontSize="10"
                                                                                       Foreground="#FFB74D" />
                                                                        </Border>
                                                                    </Grid>
                                                                    <StackPanel>
                                                                        <TextBlock Classes="DetailLabel" Text="Contact" />
                                                                        <TextBlock Text="{Binding Contact}" TextWrapping="Wrap" />
                                                                    </StackPanel>
                                                                    <Border Background="rgba(255,255,255,0.055)"
                                                                            CornerRadius="5"
                                                                            Padding="8,5">
                                                                        <TextBlock Text="{Binding DiscordStatus}"
                                                                                   FontSize="11"
                                                                                   TextWrapping="Wrap" />
                                                                    </Border>
                                                                    <Button Content="Open Discord post"
                                                                            Classes="NeutralAction"
                                                                            Tag="{Binding MessageUrl}"
                                                                            IsVisible="{Binding HasDiscordPost}"
                                                                            Click="OpenDiscordPostButton_Click"
                                                                            HorizontalAlignment="Left"
                                                                            Padding="8,4" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Expander>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Classes="DetailSection">
                                    <StackPanel Spacing="8">
                                        <TextBlock Classes="SectionTitle" Text="Traits" />
                                        <TextBlock Text="No traits" IsVisible="{Binding !HasTraits}" Opacity="0.65" />
                                        <ItemsControl ItemsSource="{Binding Traits}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:LegendaryTraitRowViewModel">
                                                    <StackPanel Spacing="4" Margin="0,0,0,8">
                                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                                                            <TextBlock Text="{Binding Value}" FontWeight="DemiBold" />
                                                            <TextBlock Grid.Column="1" Text="{Binding Name}" TextWrapping="Wrap" />
                                                            <TextBlock Grid.Column="2" Text="{Binding Rarity}" Opacity="0.65" />
                                                        </Grid>
                                                        <ProgressBar Minimum="0"
                                                                     Maximum="100"
                                                                     Value="{Binding RollPercentage}"
                                                                     Height="5"
                                                                     Foreground="#79B83A"
                                                                     Background="rgba(255,255,255,0.14)" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="0" Classes="DetailSection">
                                    <StackPanel Spacing="9">
                                        <TextBlock Classes="SectionTitle" Text="Awakened stats" />
                                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="18" RowSpacing="8">
                                            <StackPanel>
                                                <TextBlock Classes="DetailLabel" Text="Attuned to" />
                                                <TextBlock Text="{Binding AttunedTo}" FontWeight="DemiBold" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Classes="DetailLabel" Text="Strain" />
                                                <TextBlock Text="{Binding Strain}" FontWeight="DemiBold" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1">
                                                <TextBlock Classes="DetailLabel" Text="PvP fame gained" />
                                                <TextBlock Text="{Binding PvPFameGained}" FontWeight="DemiBold" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="1">
                                                <TextBlock Classes="DetailLabel" Text="Attunement" />
                                                <TextBlock Text="{Binding Attunement}" FontWeight="DemiBold" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="2" Grid.ColumnSpan="2">
                                                <TextBlock Classes="DetailLabel" Text="Attunement spent" />
                                                <TextBlock Text="{Binding AttunementSpent}" FontWeight="DemiBold" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="3" Classes="DetailSection">
                                    <StackPanel Spacing="8">
                                        <TextBlock Classes="SectionTitle" Text="Other details" />
                                        <Grid ColumnDefinitions="Auto,*"
                                              RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                              ColumnSpacing="12"
                                              RowSpacing="6">
                                            <TextBlock Grid.Row="0" Classes="DetailLabel" Text="Crafter" />
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Source.CrafterName, TargetNullValue=Unknown}" TextWrapping="Wrap" />
                                            <TextBlock Grid.Row="1" Classes="DetailLabel" Text="Location" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Location}" TextWrapping="Wrap" />
                                            <TextBlock Grid.Row="2" Classes="DetailLabel" Text="First seen" />
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FirstSeen}" TextWrapping="Wrap" />
                                            <TextBlock Grid.Row="3" Classes="DetailLabel" Text="Last seen" />
                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LastSeen}" TextWrapping="Wrap" />
                                            <TextBlock Grid.Row="4" Classes="DetailLabel" Text="Item ID" />
                                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ItemUniqueName}" TextWrapping="Wrap" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.RowSpan="3"
              IsVisible="{Binding IsAwakeningItemsTrackerDisabled}"
              Background="{DynamicResource ThemeBackgroundBrush}"
              Panel.ZIndex="10">
            <Border MaxWidth="520"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource ThemeBackgroundBrush}"
                    BorderBrush="{DynamicResource ThemeBorderMidBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="24">
                <StackPanel Spacing="8">
                    <TextBlock Text="Awakened items tracker is disabled"
                               FontSize="18"
                               FontWeight="DemiBold"
                               TextAlignment="Center" />
                    <TextBlock Text="Enable it in Settings &gt; Awakened to resume detecting and storing awakened items."
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Opacity="0.8" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
