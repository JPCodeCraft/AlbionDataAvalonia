<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AlbionDataAvalonia.ViewModels"
             xmlns:items="clr-namespace:AlbionDataAvalonia.Items"
             mc:Ignorable="d"
             d:DesignWidth="1100" d:DesignHeight="650"
             x:Class="AlbionDataAvalonia.Views.LegendaryView"
             x:DataType="vm:LegendaryViewModel">
    <Grid RowDefinitions="Auto,Auto,*" ColumnDefinitions="*">
        <WrapPanel Margin="0,8,0,8" VerticalAlignment="Top">
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Search" FontSize="12" Foreground="#888" />
                <TextBox Text="{Binding FilterText}" Width="260" Padding="8" />
            </StackPanel>
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Server" FontSize="12" Foreground="#888" />
                <ComboBox ItemsSource="{Binding Servers}" SelectedItem="{Binding SelectedServer}" Width="140" Padding="8" />
            </StackPanel>
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Data" FontSize="12" Foreground="#888" />
                <Button Content="Refresh" Command="{Binding RefreshCommand}" Padding="12,8" />
            </StackPanel>
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Entries" FontSize="12" Foreground="#888" />
                <Button Content="Delete selected"
                        Click="DeleteSelectedButton_Click"
                        Padding="12,8" />
            </StackPanel>
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Discord" FontSize="12" Foreground="#888" />
                <Button Name="SellOnDiscordButton"
                        Content="Sell on AFM Discord"
                        IsEnabled="{Binding CanSellSelectedItem}"
                        Click="SellOnDiscordButton_Click"
                        Padding="12,8" />
            </StackPanel>
        </WrapPanel>

        <TextBlock Grid.Row="1"
                   Margin="2,0,2,8"
                   Text="{Binding SaleStatus}"
                   FontSize="11"
                   TextWrapping="Wrap" />

        <Grid Grid.Row="2" ColumnDefinitions="16*,5*" ColumnSpacing="12">
            <DataGrid Name="LegendaryItemsGrid"
                      Grid.Column="0"
                      ItemsSource="{Binding Items}"
                      SelectedItem="{Binding SelectedItem}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Extended"
                      GridLinesVisibility="None"
                      BorderThickness="0">
                <DataGrid.Styles>
                    <Style Selector="DataGridColumnHeader /template/ Grid#PART_ColumnHeaderRoot">
                        <Setter Property="Background" Value="rgba(255,255,255,0.2)" />
                    </Style>
                    <Style Selector="DataGridColumnHeader:pointerover /template/ Grid#PART_ColumnHeaderRoot">
                        <Setter Property="Background" Value="rgba(255,255,255,0.4)" />
                    </Style>
                </DataGrid.Styles>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Server" Binding="{Binding ServerName}" />
                    <DataGridTemplateColumn Header="Item" SortMemberPath="ItemName" CanUserSort="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="vm:LegendaryItemRowViewModel">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Image Width="34" Height="34" Stretch="Uniform"
                                           items:LazyItemImage.ItemUniqueName="{Binding ItemUniqueName}"
                                           items:LazyItemImage.Quality="{Binding ImageQuality}" />
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ItemName}" />
                                        <TextBlock Text="{Binding SoulName}"
                                                   IsVisible="{Binding HasSoulName}"
                                                   FontSize="11"
                                                   Opacity="0.65" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Quality" Binding="{Binding Quality}" />
                    <DataGridTextColumn Header="Attuned to" Binding="{Binding AttunedTo}" SortMemberPath="Source.AttunedToPlayerName" />
                    <DataGridTextColumn Header="Attunement" Binding="{Binding Attunement}" SortMemberPath="Source.Attunement" />
                    <DataGridTextColumn Header="Rating" Binding="{Binding LegendaryRating}" SortMemberPath="LegendaryRatingValue" />
                    <DataGridTextColumn Header="Strain" Binding="{Binding Strain}" SortMemberPath="Source.Strain" />
                    <DataGridTextColumn Header="PvP fame" Binding="{Binding PvPFameGained}" SortMemberPath="Source.PvPFameGained" />
                    <DataGridTextColumn Header="Attunement spent" Binding="{Binding AttunementSpent}" SortMemberPath="Source.AttunementSpent" />
                    <DataGridTextColumn Header="Location" Binding="{Binding Location}" />
                    <DataGridTextColumn Header="Last seen" Binding="{Binding LastSeen}" SortMemberPath="Source.LastSeenAtUtc" />
                    <DataGridTextColumn Header="Discord Post" Binding="{Binding DiscordPost}" SortMemberPath="DiscordPostedAt" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="1"
                    Background="rgba(255,255,255,0.05)"
                    CornerRadius="8"
                    Padding="14">
                <Grid>
                    <TextBlock Text="Select an item to view its details."
                               IsVisible="{Binding !HasSelectedItem}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               Opacity="0.7" />
                    <ScrollViewer IsVisible="{Binding HasSelectedItem}">
                        <StackPanel Spacing="8" DataContext="{Binding SelectedItem}">
                            <TextBlock Text="Legendary item details" FontSize="18" FontWeight="DemiBold" />
                            <Image Width="90" Height="90" HorizontalAlignment="Left" Stretch="Uniform"
                                   items:LazyItemImage.ItemUniqueName="{Binding ItemUniqueName}"
                                   items:LazyItemImage.Quality="{Binding ImageQuality}" />
                            <TextBlock Text="{Binding ItemName}" FontSize="16" FontWeight="DemiBold" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SoulName}"
                                       IsVisible="{Binding HasSoulName}"
                                       FontStyle="Italic"
                                       TextWrapping="Wrap"
                                       Opacity="0.75" />
                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="4">
                                <TextBlock Grid.Row="0" Text="Server" Opacity="0.65" /><TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ServerName}" />
                                <TextBlock Grid.Row="1" Text="Quality" Opacity="0.65" /><TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Quality}" />
                                <TextBlock Grid.Row="2" Text="Crafter" Opacity="0.65" /><TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Source.CrafterName, TargetNullValue=Unknown}" />
                                <TextBlock Grid.Row="3" Text="Attuned to" Opacity="0.65" /><TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding AttunedTo}" />
                                <TextBlock Grid.Row="4" Text="Attunement" Opacity="0.65" /><TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Attunement}" />
                                <TextBlock Grid.Row="5" Text="Legendary rating" Opacity="0.65" /><TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding LegendaryRating}" />
                                <TextBlock Grid.Row="6" Text="Strain" Opacity="0.65" /><TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Strain}" />
                                <TextBlock Grid.Row="7" Text="PvP fame gained" Opacity="0.65" /><TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding PvPFameGained}" />
                                <TextBlock Grid.Row="8" Text="Attunement spent" Opacity="0.65" /><TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding AttunementSpent}" />
                                <TextBlock Grid.Row="9" Text="Location" Opacity="0.65" /><TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding Location}" />
                                <TextBlock Grid.Row="10" Text="First seen" Opacity="0.65" /><TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding FirstSeen}" />
                                <TextBlock Grid.Row="11" Text="Last seen" Opacity="0.65" /><TextBlock Grid.Row="11" Grid.Column="1" Text="{Binding LastSeen}" />
                            </Grid>
                            <TextBlock Text="Traits" FontSize="15" FontWeight="DemiBold" Margin="0,8,0,0" />
                            <TextBlock Text="No traits" IsVisible="{Binding !HasTraits}" Opacity="0.65" />
                            <ItemsControl ItemsSource="{Binding Traits}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:LegendaryTraitRowViewModel">
                                        <Border BorderBrush="rgba(255,255,255,0.12)" BorderThickness="0,0,0,1" Padding="0,7">
                                            <StackPanel Spacing="4">
                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                                                    <TextBlock Grid.Column="0" Text="{Binding Value}" FontWeight="DemiBold" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="DemiBold" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Rarity}" Opacity="0.65" />
                                                </Grid>
                                                <ProgressBar Minimum="0"
                                                             Maximum="100"
                                                             Value="{Binding RollPercentage}"
                                                             Height="5"
                                                             Foreground="#79B83A"
                                                             Background="rgba(255,255,255,0.14)" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
